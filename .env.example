# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values before running the app.
#   cp .env.example apps/web/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# A PostgreSQL connection string.
# Local option (free): install Postgres and run `createdb dharma`
#   → postgresql://postgres:password@localhost:5432/dharma
# Cloud option (free tier): https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://postgres:password@localhost:5432/dharma"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a random secret: run `openssl rand -base64 32` in your terminal
AUTH_SECRET="replace-me-with-a-random-string"

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Anthropic (optional) ─────────────────────────────────────────────────────
# If omitted, the app uses a template reply instead of AI.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
