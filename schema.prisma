generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User — one row per signed-in person.
// Created automatically on first Google sign-in via NextAuth.
// The id becomes the foreign key that ties everything else together —
// calendar credentials, future preferences, request history, etc.
model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  image             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  googleCredential  GoogleCredential?

  // NextAuth adapter tables
  accounts          Account[]
  sessions          Session[]
}

// GoogleCredential — calendar OAuth tokens, scoped to a User.
// userId FK enables multi-user: each person's tokens are stored separately.
model GoogleCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── NextAuth.js required adapter models ──────────────────────────────────────
// These are standard — NextAuth reads/writes them automatically.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
