generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  googleCredential    GoogleCredential?
  microsoftCredential MicrosoftCredential?
  appleCredential     AppleCredential?

  accounts            Account[]
  sessions            Session[]
}

model GoogleCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String   @unique
  accessToken  String
  refreshToken String
  expiresAt        DateTime
  gmailHistoryId   String?
  gmailWatchExpiry DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model MicrosoftCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Apple does not use OAuth — users generate an app-specific password at appleid.apple.com.
// The password is stored AES-256-GCM encrypted using APPLE_CREDENTIAL_ENCRYPTION_KEY.
model AppleCredential {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  appleId              String
  encryptedAppPassword String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ── NextAuth adapter models ───────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
